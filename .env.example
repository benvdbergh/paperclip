DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Required for `docker compose up` (root compose uses authenticated mode).
# Generate: openssl rand -hex 32
# BETTER_AUTH_SECRET=

# Optional: heartbeat run JWTs / injected PAPERCLIP_API_KEY for local adapters.
# If unset, docker-compose.yml defaults this to BETTER_AUTH_SECRET (same as `paperclip onboard`).
# PAPERCLIP_AGENT_JWT_SECRET=
